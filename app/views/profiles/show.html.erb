<div class="row">
  <div class="col-md-4">
    <div class="card mb-4">
      <div class="card-body">
        <h3 class="card-title">My Profile</h3>
        <hr>
        <p><strong>Phone:</strong> <%= current_user.phone %></p>
        <p><strong>Role:</strong> Patient</p>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <h3 class="mb-4">My Appointments</h3>
    
    <% if @appointments.any? %>
      <div class="list-group">
        <% @appointments.each do |appointment| %>
          <div class="list-group-item shadow-sm mb-3 border rounded">
            <div class="d-flex w-100 justify-content-between align-items-center">
              <h5 class="mb-1 text-primary">Dr. <%= appointment.doctor.first_name %> <%= appointment.doctor.last_name %></h5>
              <span class="badge <%= appointment.open? ? 'bg-warning text-dark' : 'bg-success' %>">
                <%= appointment.status.upcase %>
              </span>
            </div>
            
            <p class="mb-1 text-muted">Department: <%= appointment.doctor.category.name %></p>

            <p class="mb-1">
                <strong><i class="bi bi-calendar-check"></i> Appointment time:</strong> 
                <span class="text-success"><%= appointment.start_time.strftime("%B %d, %Y at %H:%M") %></span>
            </p>

            <p class="small text-secondary">Booked on: <%= appointment.created_at.strftime("%B %d, %Y at %H:%M") %></p>

            <% if appointment.closed? %>
              <div class="mt-3 p-3 bg-light border-start border-4 border-success">
                <strong>Doctor's Recommendation:</strong>
                <p class="mt-2 mb-0 italic">"<%= appointment.recommendation %>"</p>
              </div>
            <% else %>
              <div class="mt-2 text-info small">
                <i class="bi bi-clock"></i> Awaiting doctor's visit and recommendation.
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info">
        You don't have any appointments yet. 
        <%= link_to "Book your first appointment", categories_path, class: "alert-link" %>
      </div>
    <% end %>
  </div>
</div>
