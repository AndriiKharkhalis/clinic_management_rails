<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Doctor's Dashboard</h1>
      <p class="text-muted">Welcome, Dr. <%= @doctor.last_name %></p>
    </div>
    <div>
      <%= button_to "Logout", destroy_doctor_session_path, method: :delete, class: "btn btn-outline-danger" %>
    </div>
  </div>

  <h3 class="mb-3">Appointments</h3>
  
  <% if @appointments.any? %>
    <div class="table-responsive shadow-sm">
      <table class="table table-hover align-middle bg-white border">
        <thead class="table-light">
          <tr>
            <th>Time</th> <%# Додаємо колонку для часу %>
            <th>Patient Phone</th>
            <th>Status</th>
            <th>Recommendation & Action</th>
          </tr>
        </thead>
        <tbody>
          <% @appointments.each do |appointment| %>
            <tr>
              <td>
                <span class="text-success fw-bold">
                  <%= appointment.start_time&.strftime("%H:%M") %>
                </span>
                <br>
                <small class="text-muted"><%= appointment.start_time&.strftime("%b %d") %></small>
              </td>
              
              <td><strong><%= appointment.user.phone %></strong></td>
              <td>
                <span class="badge <%= appointment.open? ? 'bg-warning text-dark' : 'bg-success' %>">
                  <%= appointment.status.upcase %>
                </span>
              </td>
              <td>
                <% if appointment.open? %>
                  <%= form_with url: doctor_appointment_path(appointment), scope: :appointment, method: :patch, local: true, class: "row g-2" do |f| %>
                    <div class="col-8">
                      <%= f.text_area :recommendation, class: "form-control form-control-sm", placeholder: "Enter advice..." %>
                      <%= f.hidden_field :status, value: 'closed' %>
                    </div>
                    <div class="col-4">
                      <%= f.submit "Save & Close", class: "btn btn-sm btn-primary w-100" %>
                    </div>
                  <% end %>
                <% else %>
                  <p class="mb-0 text-secondary small"><em><%= appointment.recommendation %></em></p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info">No appointments yet.</div>
  <% end %>
</div>
