<!DOCTYPE html>
<html>
  <head>
    <title>Clinic Management</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Clinic Portal", root_path, class: "navbar-brand" %>

        <div class="navbar-nav ms-auto">
          <% if doctor_signed_in? %>
            <%= link_to "My Dashboard", doctor_profile_path, class: "nav-link" %>
            <%= button_to "Logout (Doctor)", destroy_doctor_session_path, method: :delete, class: "nav-link btn btn-link text-white" %>

          <% elsif user_signed_in? %>
            <%= link_to "My Profile", profile_path, class: "nav-link" %>
            <%= button_to "Logout (Patient)", destroy_user_session_path, method: :delete, class: "nav-link btn btn-link text-white" %>

          <% else %>
            <%= link_to "Login as Patient", new_user_session_path, class: "nav-link" %>
            <%= link_to "Login as Doctor", new_doctor_session_path, class: "nav-link" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container mt-4">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-check-circle-fill me-2"></i>
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>